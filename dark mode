<script>
    (function() {
        const isDark = localStorage.getItem('kg-darkMode') === 'true';
        if (isDark) {
            document.documentElement.classList.add('dark-mode');
        }
    })();
</script>

<style>
    /* Global Transitions */
    body { transition: background-color 0.3s ease, color 0.3s ease; }

    /* Dark Mode Overrides */
    .dark-mode, .dark-mode body {
        background-color: #191919 !important;
        color: #ffffff !important;
    }

    .dark-mode header, .dark-mode nav, .dark-mode footer, 
    .dark-mode .gh-head, .dark-mode .gh-foot, .dark-mode .site-header, 
    .dark-mode .site-footer, .dark-mode .gh-navigation { 
        background-color: #191919 !important; 
    }

    .dark-mode .gh-navigation-actions, .dark-mode .gh-navigation-actions *, 
    .dark-mode .gh-search, .dark-mode .gh-search-input, .dark-mode .gh-nav-search {
        background-color: #191919 !important;
        background: #191919 !important;
        color: #ffffff !important;
        border: none !important;
        box-shadow: none !important;
    }

    .dark-mode .gh-navigation-actions svg, .dark-mode .gh-search svg, .dark-mode .gh-search-icon {
        color: #ffffff !important; 
        stroke: #ffffff !important; 
        fill: none !important;
    }

    .dark-mode h1, .dark-mode h2, .dark-mode h3, .dark-mode h4, .dark-mode h5, .dark-mode h6, 
    .dark-mode p, .dark-mode span, .dark-mode a, .dark-mode li, .dark-mode blockquote, 
    .dark-mode .post-content, .dark-mode .post-excerpt, .dark-mode .gh-content { 
        color: #ffffff !important; 
    }

    .dark-mode hr, .dark-mode .gh-head, .dark-mode .gh-foot { 
        border-color: #333 !important; 
    }

    .dark-mode img { opacity: 0.95; }

    /* Icon Toggle Logic */
    .dark-mode .icon-moon { display: none !important; }
    .dark-mode .icon-sun { display: block !important; }
    .icon-sun { display: none; }

    /* Button Positioning */
    #my-unique-theme-toggle {
        position: fixed !important;
        right: 20px;
        top: 120px;
        z-index: 10000; 
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 10px;
    }
    #my-unique-theme-toggle svg { display: block; }
</style>

<button id="my-unique-theme-toggle" aria-label="Toggle theme" onclick="toggleDarkMode()">
    <div class="icon-moon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
            <path d="M21 12.79A9 9 0 1111.21 3a7 7 0 1010.8 9.79z"></path>
        </svg>
    </div>
    <div class="icon-sun">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="24" height="24">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
    </div>
</button>

<script>
    function toggleDarkMode() {
        const isDark = document.documentElement.classList.toggle('dark-mode');
        localStorage.setItem('kg-darkMode', isDark);
    }

    window.addEventListener('scroll', () => {
        const btn = document.getElementById('my-unique-theme-toggle');
        if(btn) btn.style.top = Math.max(120 - window.scrollY, 20) + 'px';
    });
</script>
